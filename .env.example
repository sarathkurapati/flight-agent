# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here

# ── API security ──────────────────────────────────────────────────────────────
# Require X-API-Key header on all agent endpoints.
# Leave commented out to disable auth (local / trusted-network use only).
# API_KEY=change-me-in-production

# ── Data storage ──────────────────────────────────────────────────────────────
# Root directory for screenshots, session logs, and the job SQLite DB.
# In containers this defaults to /tmp/browser-agent.
# Locally: set DATA_DIR=. to keep data in the project directory.
# DATA_DIR=/tmp/browser-agent

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# ── Concurrency ───────────────────────────────────────────────────────────────
# Each browser session uses ~500 MB RAM.
# MAX_CONCURRENT_SESSIONS=2

# Maximum number of pending + running jobs before POST /jobs returns 429.
# MAX_QUEUED_JOBS=100

# ── Timeouts ──────────────────────────────────────────────────────────────────
# Wall-clock cap for a single agent session (seconds).
# SESSION_TIMEOUT_SECONDS=600

# HTTP timeout for POST /run — slightly over session timeout by default.
# RUN_TIMEOUT_SECONDS=660
